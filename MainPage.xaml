<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OilDetectorApp.MainPage"
             Title="ESP32 Датчик">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Кнопки управления -->
        <HorizontalStackLayout Spacing="10">
            <Button x:Name="ScanButton" 
                    Text="🔍 Поиск" 
                    Clicked="OnScanClicked"
                    BackgroundColor="#3498db"
                    TextColor="White"
                    WidthRequest="100"/>

            <Button x:Name="ConnectButton" 
                    Text="🔌 Подключить" 
                    IsEnabled="True"
                    Clicked="OnConnectClicked"
                    BackgroundColor="#27ae60"
                    TextColor="White"
                    WidthRequest="100"/>

            <Button x:Name="DisconnectButton" 
                    Text="❌ Отключить" 
                    IsEnabled="False"
                    Clicked="OnDisconnectClicked"
                    BackgroundColor="#e74c3c"
                    TextColor="White"
                    WidthRequest="100"/>
        </HorizontalStackLayout>

        <!-- Статус -->
        <Frame BackgroundColor="#f0f0f0" Padding="10" CornerRadius="5">
            <VerticalStackLayout>
                <Label Text="📡 Статус:" FontSize="14"/>
                <Label x:Name="StatusLabel" 
                       Text="Не подключен" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="Red"/>
                <Label x:Name="DeviceNameLabel" 
                       Text="" 
                       FontSize="12"
                       TextColor="Gray"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Список устройств (скрыт, но оставлен для совместимости) -->
        <Label Text="📱 Доступные устройства:" FontSize="14" FontAttributes="Bold"/>
        <ListView x:Name="DevicesListView"
                  HeightRequest="150"
                  SelectionMode="Single"
                  BackgroundColor="White"
                  IsVisible="False">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Name}" 
                              Detail="{Binding Id}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Отображение данных датчика -->
        <Frame BackgroundColor="#2c3e50" Padding="10" CornerRadius="10">
            <VerticalStackLayout>
                <Label Text="📊 Данные с датчика:" 
                       TextColor="White" 
                       FontAttributes="Bold"/>

                <ScrollView x:Name="DataScrollView" HeightRequest="300">
                    <StackLayout x:Name="DataContainer" Spacing="5">
                        <Label x:Name="EmptyDataLabel"
                               Text="Ожидание данных..." 
                               TextColor="LightGray"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </ScrollView>

                <Button x:Name="ClearButton"
                        Text="🗑 Очистить"
                        Clicked="OnClearClicked"
                        BackgroundColor="#7f8c8d"
                        TextColor="White"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Счетчик сообщений -->
        <Label x:Name="CounterLabel" 
               Text="Получено: 0 сообщений"
               HorizontalOptions="Center"
               TextColor="Gray"
               FontSize="12"/>
    </VerticalStackLayout>
</ContentPage>